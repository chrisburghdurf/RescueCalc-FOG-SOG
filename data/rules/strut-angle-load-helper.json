{
  "id": "strut-angle-load-helper",
  "toolName": "Strut Angle / Load Helper",
  "description": "Compute strut geometry and setup checklist from insertion height and angle.",
  "placeholder": false,
  "calculator": "strutAngleLoad",
  "inputs": [
    {
      "id": "insertionHeightFt",
      "label": "Insertion Height (ft)",
      "type": "number",
      "required": true,
      "min": 1,
      "max": 30,
      "step": 0.5,
      "defaultValue": 10
    },
    {
      "id": "intendedAngleDeg",
      "label": "Intended Angle (deg)",
      "type": "select",
      "required": true,
      "options": [
        {
          "value": "45",
          "label": "45 deg"
        },
        {
          "value": "60",
          "label": "60 deg"
        }
      ],
      "defaultValue": "60"
    },
    {
      "id": "strutLengthOptionsFt",
      "label": "Longest Available Strut Length (ft)",
      "type": "number",
      "required": true,
      "min": 3,
      "max": 40,
      "step": 0.5,
      "defaultValue": 14
    },
    {
      "id": "configuration",
      "label": "Configuration",
      "type": "select",
      "required": true,
      "options": [
        {
          "value": "single",
          "label": "Single"
        },
        {
          "value": "paired",
          "label": "Paired"
        },
        {
          "value": "paired-cross",
          "label": "Paired Cross-Braced"
        }
      ],
      "defaultValue": "paired"
    }
  ],
  "assumptions": [
    "Insertion point and base anchor are measured accurately.",
    "Configuration-specific hardware is available."
  ],
  "warnings": [
    "Geometry fit does not confirm safe working load by itself.",
    "Always verify manufacturer SWL tables in uploaded manuals."
  ],
  "stepTemplates": [
    "Required strut length is {neededLengthFt} ft at {intendedAngleDeg} deg.",
    "Base offset estimate is {baseOffsetFt} ft.",
    "Configuration selected: {configuration}; fit status: {fitStatus}.",
    "If using load tables, verify exact model/extension in uploaded manual."
  ],
  "citationQueries": [
    {
      "query": "raker shore angle 45 60 insertion height base offset",
      "preferredSource": "SOG"
    },
    {
      "query": "building stabilization shoring field guide raker geometry",
      "preferredSource": "OTHER"
    }
  ]
}
